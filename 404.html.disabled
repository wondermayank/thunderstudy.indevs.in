<!DOCTYPE html>
<html lang="en-IN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>404 — Page Not Found · ThunderStudy</title>
<meta name="description" content="Oops! The page you're looking for doesn't exist on ThunderStudy. Return to the home page for free CBSE Class 12 notes, CUET mock tests, SSC and Banking CBT mocks.">
<meta name="robots" content="noindex, follow">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="canonical" href="https://thunderstudy.indevs.in/404">

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@600;700;800&display=swap');

  :root {
    --blue-100: #e0f0ff;
    --blue-200: #bad8ff;
    --blue-300: #7ab8ff;
    --blue-400: #3b9eff;
    --blue-500: #0077f5;
    --purple-100: #f0e8ff;
    --purple-200: #d8c0ff;
    --purple-300: #b07aff;
    --purple-400: #8b45ff;
    --purple-500: #6d28d9;
    --accent: #ff6b35;
    --white: #ffffff;
    --gray-50: #f8fafc;
    --gray-100: #f1f5f9;
    --gray-200: #e2e8f0;
    --gray-400: #94a3b8;
    --gray-600: #475569;
    --gray-800: #0f172a;
    --font-display: 'Syne', sans-serif;
    --font-body: 'DM Sans', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--white);
    color: var(--gray-800);
    overflow-x: hidden;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── HEADER ── */
  header {
    background: linear-gradient(135deg, #dbeeff 0%, #ede8ff 60%, #f8f4ff 100%);
    border-bottom: 1px solid var(--blue-200);
    padding: 0 24px;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
  }
  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo-group { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  .logo-icon { width: 34px; height: 34px; }
  .logo-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    background: linear-gradient(90deg, #1e88e5, #7c3aed);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .header-badge {
    font-size: 0.72rem;
    font-weight: 600;
    background: linear-gradient(90deg, var(--blue-500), var(--purple-400));
    color: white;
    padding: 4px 10px;
    border-radius: 99px;
    letter-spacing: 0.3px;
  }

  /* ── 404 HERO ── */
  .error-page {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 24px;
    background: linear-gradient(135deg, #dbeeff 0%, #ede8ff 55%, #f8f4ff 100%);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  /* Decorative orbs */
  .error-page::before {
    content: '';
    position: absolute;
    width: 700px; height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(168,85,247,0.09) 0%, transparent 65%);
    top: -260px; right: -120px;
    pointer-events: none;
  }
  .error-page::after {
    content: '';
    position: absolute;
    width: 500px; height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(30,136,229,0.08) 0%, transparent 65%);
    bottom: -120px; left: -100px;
    pointer-events: none;
  }

  .error-content {
    position: relative;
    z-index: 1;
    max-width: 580px;
    margin: 0 auto;
  }

  /* ── SVG ANIMATION STAGE ── */
  .anim-stage {
    width: 340px;
    height: 240px;
    margin: 0 auto 40px;
    position: relative;
  }

  /* Big glassy 404 text */
  .num-404 {
    font-family: var(--font-display);
    font-size: clamp(5rem, 18vw, 9rem);
    font-weight: 800;
    letter-spacing: -4px;
    line-height: 1;
    background: linear-gradient(135deg, #1e3a5f 0%, #1e88e5 40%, #7c3aed 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: floatNum 4s ease-in-out infinite;
    display: block;
    position: relative;
    user-select: none;
  }
  @keyframes floatNum {
    0%, 100% { transform: translateY(0px); filter: drop-shadow(0 12px 32px rgba(30,136,229,0.18)); }
    50%       { transform: translateY(-14px); filter: drop-shadow(0 28px 48px rgba(124,58,237,0.22)); }
  }

  /* Ghost astronaut SVG */
  .ghost-wrap {
    position: absolute;
    bottom: 0; right: -10px;
    width: 120px;
    animation: floatGhost 3.5s ease-in-out infinite;
  }
  @keyframes floatGhost {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50%       { transform: translateY(-18px) rotate(2deg); }
  }

  /* Shadow under ghost */
  .ghost-shadow {
    position: absolute;
    bottom: -4px; right: 15px;
    width: 90px; height: 14px;
    background: radial-gradient(ellipse, rgba(109,40,217,0.22) 0%, transparent 70%);
    border-radius: 50%;
    animation: shadowPulse 3.5s ease-in-out infinite;
  }
  @keyframes shadowPulse {
    0%, 100% { transform: scaleX(1); opacity: 0.6; }
    50%       { transform: scaleX(0.65); opacity: 0.25; }
  }

  /* Floating particles */
  .particle {
    position: absolute;
    border-radius: 50%;
    animation: drift linear infinite;
    opacity: 0;
  }
  @keyframes drift {
    0%   { transform: translateY(0) scale(1); opacity: 0; }
    15%  { opacity: 1; }
    85%  { opacity: 0.7; }
    100% { transform: translateY(-200px) scale(0.3); opacity: 0; }
  }

  /* Orbiting ring */
  .orbit-ring {
    position: absolute;
    top: 50%; left: 50%;
    width: 280px; height: 280px;
    margin: -140px 0 0 -140px;
    border: 1.5px dashed rgba(124,58,237,0.18);
    border-radius: 50%;
    animation: spinRing 18s linear infinite;
    pointer-events: none;
  }
  @keyframes spinRing {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .orbit-dot {
    position: absolute;
    top: -5px; left: calc(50% - 5px);
    width: 10px; height: 10px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1e88e5, #7c3aed);
    box-shadow: 0 0 10px rgba(124,58,237,0.5);
  }

  /* ── TEXT CONTENT ── */
  .error-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--purple-500);
    background: var(--purple-100);
    border: 1px solid var(--purple-200);
    padding: 5px 14px;
    border-radius: 99px;
    margin-bottom: 20px;
  }

  .error-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.5px;
    color: var(--gray-800);
    margin-bottom: 14px;
    line-height: 1.2;
  }

  .error-desc {
    font-size: 1rem;
    color: var(--gray-600);
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 440px;
    margin-left: auto;
    margin-right: auto;
  }

  .error-btns {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 12px;
    font-size: 0.92rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    background: linear-gradient(135deg, #0077f5 0%, #6d28d9 100%);
    color: white;
    box-shadow: 0 4px 18px rgba(30,136,229,0.28);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(30,136,229,0.38); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border-radius: 12px;
    font-size: 0.92rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
    background: var(--white);
    color: var(--blue-500);
    border: 1.5px solid var(--blue-200);
    box-shadow: 0 2px 8px rgba(0,119,245,0.08);
  }
  .btn-secondary:hover { transform: translateY(-2px); background: var(--blue-100); }

  /* Quick links */
  .quick-title {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--blue-500);
    margin-bottom: 16px;
  }
  .quick-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }
  .quick-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 10px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--gray-600);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, background 0.2s, transform 0.2s;
  }
  .quick-chip:hover { border-color: var(--blue-300); color: var(--blue-500); background: var(--blue-100); transform: translateY(-1px); }
  .quick-chip svg { width: 14px; height: 14px; flex-shrink: 0; }

  /* ── FOOTER ── */
  footer {
    background: #0f172a;
    color: #94a3b8;
    padding: 0;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 56px 24px 32px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.8fr repeat(4, 1fr);
    gap: 40px;
    margin-bottom: 40px;
  }
  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    background: linear-gradient(90deg, #60a5fa, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 10px;
  }
  .footer-tagline {
    font-size: 0.83rem;
    line-height: 1.6;
    color: #64748b;
    margin-bottom: 16px;
  }
  .footer-col h4 {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #e2e8f0;
    margin-bottom: 16px;
  }
  .footer-col a {
    display: block;
    font-size: 0.83rem;
    color: #64748b;
    text-decoration: none;
    margin-bottom: 9px;
    transition: color 0.2s;
    line-height: 1.4;
  }
  .footer-col a:hover { color: #93c5fd; }
  .footer-col a .badge-small {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    background: rgba(96,165,250,0.12);
    color: #93c5fd;
    border-radius: 5px;
    padding: 1px 5px;
    margin-left: 5px;
    vertical-align: middle;
  }
  .footer-divider {
    border: none;
    border-top: 1px solid #1e293b;
    margin-bottom: 24px;
  }
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 0.78rem;
    color: #475569;
  }
  .footer-bottom a { color: #64748b; text-decoration: none; transition: color 0.2s; }
  .footer-bottom a:hover { color: #93c5fd; }
  .footer-legal-links { display: flex; gap: 16px; flex-wrap: wrap; align-items: center; }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-col:first-child { grid-column: 1 / -1; }
  }
  @media (max-width: 540px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 28px; }
    .footer-col:first-child { grid-column: 1 / -1; }
    .anim-stage { width: 280px; height: 200px; }
    .ghost-wrap { width: 90px; }
    .orbit-ring { width: 220px; height: 220px; margin: -110px 0 0 -110px; }
  }
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="header-inner">
    <a class="logo-group" href="https://thunderstudy.indevs.in/" aria-label="ThunderStudy Home">
      <!-- Thunder bolt logo SVG -->
      <svg class="logo-icon" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="34" height="34" rx="9" fill="url(#logo-grad)"/>
        <path d="M20 4L10 19h8l-4 11 14-15h-9L20 4z" fill="white"/>
        <defs>
          <linearGradient id="logo-grad" x1="0" y1="0" x2="34" y2="34">
            <stop offset="0%" stop-color="#1e88e5"/>
            <stop offset="100%" stop-color="#7c3aed"/>
          </linearGradient>
        </defs>
      </svg>
      <span class="logo-text">ThunderStudy</span>
    </a>
    <span class="header-badge">Free Education For All</span>
  </div>
</header>

<!-- 404 SECTION -->
<main class="error-page" role="main">
  <!-- Orbiting ring decoration -->
  <div class="orbit-ring" aria-hidden="true">
    <div class="orbit-dot"></div>
  </div>

  <!-- Floating particles -->
  <div class="particle" aria-hidden="true" style="width:8px;height:8px;background:#7ab8ff;left:15%;top:70%;animation-duration:6s;animation-delay:0s;"></div>
  <div class="particle" aria-hidden="true" style="width:5px;height:5px;background:#b07aff;left:80%;top:80%;animation-duration:8s;animation-delay:1.5s;"></div>
  <div class="particle" aria-hidden="true" style="width:6px;height:6px;background:#3b9eff;left:25%;top:60%;animation-duration:7s;animation-delay:0.8s;"></div>
  <div class="particle" aria-hidden="true" style="width:4px;height:4px;background:#8b45ff;left:72%;top:55%;animation-duration:9s;animation-delay:2.2s;"></div>
  <div class="particle" aria-hidden="true" style="width:7px;height:7px;background:#60a5fa;left:10%;top:50%;animation-duration:7.5s;animation-delay:3s;"></div>
  <div class="particle" aria-hidden="true" style="width:5px;height:5px;background:#a78bfa;left:88%;top:65%;animation-duration:6.5s;animation-delay:1s;"></div>

  <div class="error-content">

    <!-- Animated 404 + Ghost stage -->
    <div class="anim-stage" aria-hidden="true">
      <span class="num-404">404</span>
      <div class="ghost-shadow"></div>
      <div class="ghost-wrap">
        <!-- Cute ghost / lost astronaut SVG -->
        <svg viewBox="0 0 100 130" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="gh-body" x1="10" y1="20" x2="90" y2="120" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#e0f0ff"/>
              <stop offset="100%" stop-color="#f0e8ff"/>
            </linearGradient>
            <linearGradient id="gh-visor" x1="30" y1="40" x2="70" y2="65" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#7ab8ff" stop-opacity="0.9"/>
              <stop offset="100%" stop-color="#b07aff" stop-opacity="0.7"/>
            </linearGradient>
          </defs>
          <!-- Body -->
          <ellipse cx="50" cy="65" rx="34" ry="40" fill="url(#gh-body)" stroke="#bad8ff" stroke-width="1.5"/>
          <!-- Helmet -->
          <ellipse cx="50" cy="42" rx="30" ry="28" fill="url(#gh-body)" stroke="#bad8ff" stroke-width="1.5"/>
          <!-- Visor -->
          <ellipse cx="50" cy="43" rx="20" ry="16" fill="url(#gh-visor)"/>
          <!-- Visor shine -->
          <ellipse cx="42" cy="37" rx="5" ry="4" fill="white" opacity="0.5"/>
          <!-- Eyes inside visor -->
          <circle cx="43" cy="44" r="4" fill="white"/>
          <circle cx="57" cy="44" r="4" fill="white"/>
          <circle cx="44" cy="44" r="2.2" fill="#1e3a5f"/>
          <circle cx="58" cy="44" r="2.2" fill="#1e3a5f"/>
          <!-- Confused mouth -->
          <path d="M44 53 Q50 50 56 53" stroke="#475569" stroke-width="1.5" stroke-linecap="round" fill="none"/>
          <!-- Left arm -->
          <ellipse cx="18" cy="70" rx="8" ry="14" fill="url(#gh-body)" stroke="#bad8ff" stroke-width="1.5" transform="rotate(-15 18 70)"/>
          <!-- Right arm — waving -->
          <ellipse cx="82" cy="62" rx="8" ry="14" fill="url(#gh-body)" stroke="#bad8ff" stroke-width="1.5" transform="rotate(25 82 62)"/>
          <!-- Suit detail — chest badge -->
          <rect x="40" y="72" width="20" height="14" rx="4" fill="#bad8ff" opacity="0.6"/>
          <circle cx="50" cy="79" r="4" fill="#3b9eff" opacity="0.7"/>
          <!-- Legs / base -->
          <ellipse cx="37" cy="103" rx="11" ry="8" fill="url(#gh-body)" stroke="#bad8ff" stroke-width="1.5"/>
          <ellipse cx="63" cy="103" rx="11" ry="8" fill="url(#gh-body)" stroke="#bad8ff" stroke-width="1.5"/>
          <!-- Question mark above head -->
          <text x="72" y="18" font-size="22" font-family="Syne, sans-serif" font-weight="800" fill="#8b45ff" opacity="0.85" style="animation:none">?</text>
        </svg>
      </div>
    </div>

    <span class="error-tag">Error 404 · Lost in Space</span>

    <h1 class="error-title">This page drifted into a black hole</h1>
    <p class="error-desc">
      The page you're looking for doesn't exist, was moved, or the URL might have a typo. 
      Don't worry — ThunderStudy still has everything you need to ace your exams!
    </p>

    <div class="error-btns">
      <a class="btn-primary" href="https://thunderstudy.indevs.in/">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12L12 3l9 9"/><path d="M9 21V12h6v9"/></svg>
        Back to Home
      </a>
      <a class="btn-secondary" href="https://commercesehoga.github.io/dashboard">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/></svg>
        CBT Mock Platform
      </a>
    </div>

    <!-- Quick links -->
    <div>
      <p class="quick-title">Quick Links</p>
      <div class="quick-grid">
        <a class="quick-chip" href="https://commercesehoga.github.io/cuet">
          <svg viewBox="0 0 24 24" fill="none" stroke="#1e88e5" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/></svg>
          CUET Mock
        </a>
        <a class="quick-chip" href="https://commercesehoga.github.io/ssc">
          <svg viewBox="0 0 24 24" fill="none" stroke="#1e88e5" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 3v18"/></svg>
          SSC Mock
        </a>
        <a class="quick-chip" href="https://commercesehoga.github.io/banking">
          <svg viewBox="0 0 24 24" fill="none" stroke="#1e88e5" stroke-width="2"><path d="M3 21h18M6 21V10M18 21V10M2 10h20M12 3L2 10h20z"/></svg>
          Banking Mock
        </a>
        <a class="quick-chip" href="https://commercesehoga.github.io/commerce">
          <svg viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          Commerce
        </a>
        <a class="quick-chip" href="https://commercesehoga.github.io/science">
          <svg viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>
          Science
        </a>
        <a class="quick-chip" href="https://commercesehoga.github.io/gat">
          <svg viewBox="0 0 24 24" fill="none" stroke="#1e88e5" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          GAT Test
        </a>
        <a class="quick-chip" href="https://wondermayank.github.io/Current_Affairs/">
          <svg viewBox="0 0 24 24" fill="none" stroke="#ff6b35" stroke-width="2"><path d="M4 22V12a8 8 0 0 1 16 0v10"/><path d="M2 22h20"/></svg>
          Current Affairs
        </a>
        <a class="quick-chip" href="https://commercesehoga.github.io/fqa">
          <svg viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Ask a Question
        </a>
      </div>
    </div>

  </div>
</main>

<!-- FOOTER -->
<footer>
  <div class="footer-inner">
    <div class="footer-grid">

      <!-- Brand col -->
      <div class="footer-col">
        <div class="footer-logo">ThunderStudy</div>
        <div class="footer-tagline">Free Education For All<br>By Thunder Team · Wondermayank</div>
      </div>

      <!-- Platforms -->
      <div class="footer-col">
